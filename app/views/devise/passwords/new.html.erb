<div class="w-full h-[calc(100vh-150px)] flex flex-col items-center justify-center">
  <h2 class="text-3xl font-bold mb-5">Forgot Your Password?</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="field mb-3">
      <p><%= f.label :email %></p>
      <p><%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-field-input" %></p>
    </div>

    <div class="actions mb-4 bg-[var(--primary)] px-7 text-center rounded-md py-[2px] cursor-pointer">
      <%= f.submit "Send me password reset instructions" %>
    </div>
  <% end %>

  <div class="flex flex-col items-center text-[var(--primary)]">
  <%= render "devise/shared/links" %>
  </div>
</div>
